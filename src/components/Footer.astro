const currentYear = new Date().getFullYear();
---

<footer id="contacto" class="footer" role="contentinfo">
    <div class="container">
        <div class="footer-content">
            <div class="footer-brand">
                <img src="/Logo.png" alt="Logo de Central de Hamburguesas" class="footer-logo" loading="lazy" decoding="async" />
                <p>La central del sabor urbano. Auténtico, callejero y delicioso.</p>
            </div>
            <div class="footer-contact">
                <h3>¡Haz tu pedido!</h3>
                <a href="https://wa.me/5215519082651" target="_blank" rel="noopener noreferrer" class="whatsapp-link" aria-label="Enviar pedido por WhatsApp al 55 1908 2651">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                    55 1908 2651
                </a>
                <p class="delivery-note">Entrega a domicilio disponible</p>
            </div>
            <div class="footer-social">
                <h3>Síguenos</h3>
                <div class="social-links">
                    <a href="#" aria-label="Facebook de Central de Hamburguesas"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
                    <a href="#" aria-label="Instagram de Central de Hamburguesas"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
                    <a href="#" aria-label="TikTok de Central de Hamburguesas"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg></a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; {currentYear} Central de Hamburguesas. Todos los derechos reservados.</p>
        </div>
    </div>

    <!-- Floating WhatsApp Button -->
    <a href="https://wa.me/5215519082651" target="_blank" rel="noopener noreferrer" class="whatsapp-float" aria-label="Pedir por WhatsApp">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
    </a>
</footer>

<style>
    .footer {
        background-color: #0a0a0a;
        padding: 4rem 0 2rem;
        border-top: 4px solid var(--color-primary);
        position: relative;
    }

    .footer-content {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 3rem;
        margin-bottom: 3rem;
    }

    .footer-brand .footer-logo {
        height: 80px;
        margin-bottom: 1rem;
        filter: drop-shadow(0 0 8px rgba(255, 193, 7, 0.3));
    }

    .footer-brand p {
        color: var(--color-text-muted);
        max-width: 300px;
        line-height: 1.6;
    }

    .footer-contact h3, .footer-social h3 {
        font-family: var(--font-display);
        font-size: 1.5rem;
        margin-bottom: 1rem;
        color: var(--color-primary);
    }

    .whatsapp-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #25D366;
        font-size: 1.5rem;
        font-weight: 700;
        text-decoration: none;
        margin-bottom: 1rem;
        transition: color 0.3s, transform 0.2s;
    }

    .whatsapp-link:hover {
        color: #128C7E;
        transform: translateX(4px);
    }

    .delivery-note {
        color: var(--color-text-muted);
        font-size: 0.9rem;
    }

    .social-links {
        display: flex;
        gap: 1rem;
    }

    .social-links a {
        color: var(--color-text);
        background: var(--color-surface);
        padding: 0.75rem;
        border-radius: 50%;
        display: flex;
        transition: background 0.3s, color 0.3s, transform 0.2s;
    }

    .social-links a:hover {
        background: var(--color-primary);
        color: var(--color-bg);
        transform: translateY(-3px);
    }

    .social-links a:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
    }

    .footer-bottom {
        text-align: center;
        padding-top: 2rem;
        border-top: 1px solid #333;
        color: var(--color-text-muted);
        font-size: 0.9rem;
    }

    .whatsapp-float {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background-color: #25D366;
        color: white;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);
        z-index: 1000;
        transition: transform 0.3s, box-shadow 0.3s;
        animation: pulse-float 2s ease-in-out infinite;
    }

    .whatsapp-float:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 20px rgba(37, 211, 102, 0.6);
        animation: none;
    }

    @keyframes pulse-float {
        0% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.7); }
        70% { box-shadow: 0 0 0 15px rgba(37, 211, 102, 0); }
        100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0); }
    }

    @media (max-width: 768px) {
        .whatsapp-float {
            width: 50px;
            height: 50px;
            bottom: 20px;
            right: 20px;
        }
        .whatsapp-float svg {
            width: 24px;
            height: 24px;
        }
    }
</style>