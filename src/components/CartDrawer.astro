---
---

<div id="cart-backdrop" class="fixed inset-0 bg-black/70 backdrop-blur-sm z-[1998] opacity-0 invisible transition-all duration-300" aria-hidden="true"></div>

<aside 
    id="cart-drawer" 
    class="fixed top-0 right-0 w-full max-w-md h-full bg-neutral z-[1999] flex flex-col shadow-2xl translate-x-full transition-transform duration-300 ease-out"
    role="dialog"
    aria-label="Mi Pedido"
    aria-hidden="true"
>
    <header class="flex items-center justify-between p-6 border-b-2 border-primary bg-gradient-to-r from-neutral to-base-300">
        <h2 class="font-display text-3xl text-primary tracking-wider">MI PEDIDO</h2>
        <button 
            id="cart-close" 
            class="btn btn-circle btn-ghost text-neutral-content hover:bg-error hover:text-error-content transition-all"
            aria-label="Cerrar carrito"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </header>

    <div id="cart-empty" class="flex-1 flex flex-col items-center justify-center gap-4 text-neutral-content/60 p-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20 opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="9" cy="21" r="1"/>
            <circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <p class="text-xl font-bold text-neutral-content">Tu carrito está vacío</p>
        <span class="text-sm text-center">Agrega combos para comenzar tu pedido</span>
        <button id="cart-continue" class="btn btn-outline btn-primary mt-4">
            Explorar el menú
        </button>
    </div>

    <div id="cart-items" class="flex-1 overflow-y-auto p-4 space-y-3">
    </div>

    <footer id="cart-footer" class="hidden p-6 border-t-2 border-primary bg-neutral space-y-4">
        <div class="flex items-center justify-between">
            <span class="text-lg font-bold text-neutral-content">Total</span>
            <span id="cart-total" class="font-display text-4xl text-primary">$0</span>
        </div>
        
        <button 
            id="cart-whatsapp-btn" 
            class="btn btn-success w-full font-bold uppercase tracking-wider text-lg h-14 gap-2"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar por WhatsApp
        </button>
        
        <button id="cart-continue-shopping" class="btn btn-outline w-full font-bold uppercase tracking-wider">
            Seguir ordenando
        </button>
    </footer>
</aside>

<style>
    #cart-drawer.open {
        transform: translateX(0);
    }
    
    #cart-backdrop.visible {
        opacity: 1;
        visibility: visible;
    }
    
    #cart-items::-webkit-scrollbar {
        width: 4px;
    }
    
    #cart-items::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
    }
    
    #cart-items::-webkit-scrollbar-thumb {
        background: oklch(var(--p));
        border-radius: 2px;
    }
</style>
