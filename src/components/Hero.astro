---

<section id="inicio" class="hero" aria-label="Sección principal de Central de Hamburguesas">
    <div class="hero-background" aria-hidden="true"></div>
    <div class="container hero-content">
        <div class="hero-text">
            <h1 class="hero-title">
                <span class="hero-brand">Central de Hamburguesas</span>
                <span class="hero-tagline">Sabor que Manda</span>
            </h1>
            <p class="hero-subtitle">
                La central del sabor urbano. Hamburguesas, boneless, hot dogs y más. 
                ¡Directo a tu puerta con la actitud que nos caracteriza!
            </p>
            <div class="hero-buttons">
                <a href="#menu" class="btn btn-primary">Ver Menú</a>
                <a href="https://wa.me/5215519082651" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Pedir por WhatsApp</a>
            </div>
        </div>
        <div class="hero-characters">
            <img 
                src="/burger.png" 
                alt="Hamburguesa gigante de Central de Hamburguesas" 
                class="hero-burger" 
                fetchpriority="high" 
            />
        </div>
    </div>
    <div class="hero-wave" aria-hidden="true">
        <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="#121212"/>
        </svg>
    </div>
    <a href="#combos" class="scroll-indicator" aria-label="Desplázate hacia abajo para ver los combos">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
    </a>
</section>

<style>
    .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding-top: 80px;
        background: radial-gradient(circle at 50% 50%, #2a2a2a 0%, #121212 100%);
    }

    .hero-background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image:
            radial-gradient(circle at 20% 50%, rgba(255, 140, 0, 0.04) 0%, transparent 50%),
            radial-gradient(circle at 80% 20%, rgba(255, 100, 0, 0.04) 0%, transparent 50%),
            repeating-linear-gradient(
                45deg,
                transparent,
                transparent 40px,
                rgba(255, 255, 255, 0.01) 40px,
                rgba(255, 255, 255, 0.01) 41px
            );
        z-index: 0;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 0;
        align-items: center;
        width: 100%;
    }

    .hero-text {
        position: relative;
        z-index: 2;
        padding-right: 0;
        margin-right: -120px;
    }

    .hero-title {
        font-family: var(--font-display);
        line-height: 0.95;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        text-shadow: 4px 4px 0px rgba(0,0,0,0.5);
    }

    .hero-brand {
        display: block;
        font-size: 3.5rem;
        color: #FF6600;
        text-shadow: 3px 3px 0px rgba(0,0,0,0.6);
        margin-bottom: 0.3rem;
    }

    .hero-tagline {
        display: block;
        font-size: 6rem;
        color: var(--color-text);
        text-shadow: 4px 4px 0px rgba(0,0,0,0.6);
    }

    .hero-subtitle {
        font-size: 1.25rem;
        color: var(--color-text-muted);
        margin-bottom: 2.5rem;
        max-width: 500px;
        line-height: 1.6;
    }

    .hero-buttons {
        display: flex;
        gap: 1rem;
    }

    .btn {
        padding: 1rem 2.5rem;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 700;
        font-size: 1rem;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 1px;
        border: none;
        cursor: pointer;
        display: inline-block;
    }

    .btn-primary {
        background-color: var(--color-primary);
        color: var(--color-bg);
        box-shadow: 0 4px 20px rgba(255, 193, 7, 0.4);
    }

    .btn-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(255, 193, 7, 0.6);
    }

    .btn-secondary {
        background-color: transparent;
        color: var(--color-text);
        border: 2px solid var(--color-secondary);
    }

    .btn-secondary:hover {
        background-color: var(--color-secondary);
        color: white;
        transform: translateY(-3px);
    }

    .hero-characters {
        position: relative;
        height: 700px;
        width: 100%;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-burger {
        max-height: 100%;
        max-width: 100%;
        width: auto;
        height: auto;
        transform: scaleX(-1) scale(1.25);
        filter: drop-shadow(0 10px 30px rgba(0,0,0,0.5));
        object-fit: contain;
    }

    .hero-wave {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        line-height: 0;
        z-index: 2;
    }

    .scroll-indicator {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 3;
        color: var(--color-primary);
        animation: bounce 2s ease-in-out infinite;
        opacity: 0.7;
        transition: opacity 0.3s;
    }

    .scroll-indicator:hover {
        opacity: 1;
    }

    @keyframes bounce {
        0%, 100% { transform: translateX(-50%) translateY(0); }
        50% { transform: translateX(-50%) translateY(10px); }
    }

    @media (max-width: 968px) {
        .hero-content {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 2rem;
        }

        .hero-text {
            margin-right: 0;
            order: 1;
        }

        .hero-brand {
            font-size: 2.5rem;
        }

        .hero-tagline {
            font-size: 4rem;
        }

        .hero-subtitle {
            margin: 0 auto 2.5rem;
        }

        .hero-buttons {
            justify-content: center;
            flex-wrap: wrap;
        }

        .hero-characters {
            height: 450px;
            order: -1;
        }
    }

    @media (max-width: 480px) {
        .hero-brand {
            font-size: 2rem;
        }

        .hero-tagline {
            font-size: 3rem;
        }

        .btn {
            padding: 0.85rem 1.5rem;
            font-size: 0.9rem;
        }

        .hero-characters {
            height: 380px;
        }
    }
</style>
